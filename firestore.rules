rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidRoom(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
             data.startDate is string && data.startDate.matches("^\\d{4}-\\d{2}-\\d{2}.*$") &&
             data.endDate is string && data.endDate.matches("^\\d{4}-\\d{2}-\\d{2}.*$") &&
             data.createdAt is string;
    }

    function isValidResponse(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 30 &&
             data.selectedDates is list && data.selectedDates.size() <= 60 && // Limit to ~2 months of days
             data.updatedAt is string;
    }

    // Room rules
    match /rooms/{roomId} {
      allow read: if true; // Publicly readable via link
      allow create: if isValidRoom(request.resource.data);
      allow update, delete: if false; // For MVP, rooms are immutable after creation

      // Response rules
      match /responses/{responseId} {
        allow read: if true;
        allow create, update: if isValidResponse(request.resource.data);
        allow delete: if false;
      }
    }
  }
}
