{
  "entities": {
    "Room": {
      "title": "Room",
      "description": "일정 조율을 위한 방 정보",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "방 제목" },
        "startDate": { "type": "string", "format": "date", "description": "조율 시작일 (ISO string)" },
        "endDate": { "type": "string", "format": "date", "description": "조율 종료일 (ISO string)" },
        "createdAt": { "type": "string", "format": "date-time", "description": "생성 시간" },
        "createdBy": { "type": "string", "description": "생성자 UID" }
      },
      "required": ["title", "startDate", "endDate", "createdAt"]
    },
    "Response": {
      "title": "Response",
      "description": "참여자의 응답 정보",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "참여자 이름" },
        "selectedDates": { 
          "type": "array", 
          "items": { "type": "string" }, 
          "description": "선택한 날짜들 (ISO date strings)" 
        },
        "updatedAt": { "type": "string", "format": "date-time", "description": "수정 시간" }
      },
      "required": ["name", "selectedDates", "updatedAt"]
    }
  },
  "firestore": {
    "/rooms/{roomId}": {
      "schema": "Room",
      "description": "일정 조율 방"
    },
    "/rooms/{roomId}/responses/{responseId}": {
      "schema": "Response",
      "description": "방의 참여자 응답 목록"
    }
  }
}
